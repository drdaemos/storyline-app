        },
        {
          "id": "b_persuade",
          "type": "plain",
          "intent": "The guard softens but does not yield; Mara learns his name",
          "effects": [ { "var": "guard_trust", "op": "inc", "value": 1 } ],
          "next": "b_talk"
        },
        {
          "id": "b_sneak",
